# Copy to .env and fill in. .env is gitignored.

# Generation (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-4-6

# Embeddings (OpenAI) — https://platform.openai.com
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Database (external Postgres with pgvector)
DATABASE_URL=postgresql+psycopg://sec:sec@localhost:5432/sec

# SEC EDGAR requires a descriptive User-Agent: "Name email"
SEC_USER_AGENT=sec-insight you@example.com

# Redis (arq job queue for async ingest worker)
REDIS_URL=redis://localhost:6379

# Market data (Phase 3, optional to start)
MARKET_DATA_API_KEY=
